<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:clipToOutline="true">

    <!-- Row 1: Current prayer + remaining time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left: Prayer name + time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prayer"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="16sp"
                android:autoSizeMaxTextSize="24sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textDirection="locale"
                android:textColor="#BFFFFFFF"
                android:textSize="16sp"
                android:fontFeatureSettings="tnum"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="18sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>

        <!-- Center-right: Remaining label + countdown -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/remaining_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="Remaining Time"
                    android:textColor="#B3FFFFFF"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:gravity="end"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="14sp"
                    android:autoSizeStepGranularity="1sp"/>
                <Chronometer
                    android:id="@+id/remaining_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textDirection="locale"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFeatureSettings="tnum"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="18sp"
                    android:autoSizeMaxTextSize="28sp"
                    android:autoSizeStepGranularity="1sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:baselineAligned="false"
                android:layout_marginTop="-2dp">
                <TextView
                    android:id="@+id/jamaat_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="Jamaat N/A"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:gravity="end"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="13sp"
                    android:autoSizeStepGranularity="1sp"/>
                <Chronometer
                    android:id="@+id/jamaat_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textDirection="locale"
                    android:textColor="#26A69A"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFeatureSettings="tnum"
                    android:maxLines="1"
                    android:visibility="gone"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="14sp"
                    android:autoSizeMaxTextSize="24sp"
                    android:autoSizeStepGranularity="1sp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Row 2: 4 prayer times (excludes current prayer) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <!-- Slot 1 -->
        <LinearLayout
            android:id="@+id/row_slot_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/widget_slot_bg_transparent">
            <TextView
                android:id="@+id/row_label_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/row_time_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textDirection="locale"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:gravity="center"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>

        <!-- Slot 2 -->
        <LinearLayout
            android:id="@+id/row_slot_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/widget_slot_bg_transparent">
            <TextView
                android:id="@+id/row_label_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/row_time_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textDirection="locale"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:gravity="center"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>

        <!-- Slot 3 -->
        <LinearLayout
            android:id="@+id/row_slot_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/widget_slot_bg_transparent">
            <TextView
                android:id="@+id/row_label_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/row_time_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textDirection="locale"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:gravity="center"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>

        <!-- Slot 4 -->
        <LinearLayout
            android:id="@+id/row_slot_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/widget_slot_bg_transparent">
            <TextView
                android:id="@+id/row_label_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/row_time_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textDirection="locale"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:gravity="center"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Ambient glow band: snaps to one of 6 positions matching the current period
         (Fajr, Sunrise, Dhuhr, Asr, Maghrib, Isha). Bitmap is rendered in
         PrayerWidgetProvider.renderGlowBand(). -->
    <ImageView
        android:id="@+id/glow_band"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_marginTop="2dp"
        android:scaleType="fitXY"
        android:contentDescription="@null"/>

    <!-- Row 3: Hijri + Bangla date (line 1) + location (line 2) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp">

        <!-- Line 1: App icon + calendar icon + Hijri & Bangla date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@mipmap/launcher_icon"
                android:contentDescription="App icon"
                android:layout_marginEnd="4dp"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="#FFFFFF"
                android:contentDescription="Calendar"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/islamic_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Islamic Date"
                android:textDirection="locale"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Line 2: Location icon + name + refresh (bottom-right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">
            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#B3FFFFFF"
                android:contentDescription="Location"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Location"
                android:textDirection="locale"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

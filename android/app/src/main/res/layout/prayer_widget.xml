<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp"
    android:clipToOutline="true">

    <!-- Row 1: Current prayer + remaining time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left: Prayer name + time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prayer"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:maxLines="1"/>
        </LinearLayout>

        <!-- Center-right: Remaining label + countdown -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/remaining_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="Remaining Time"
                    android:textColor="#B3FFFFFF"
                    android:textSize="15sp"
                    android:maxLines="1"
                    android:gravity="end"/>
                <Chronometer
                    android:id="@+id/remaining_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:maxLines="1"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:baselineAligned="false"
                android:layout_marginTop="-2dp">
                <TextView
                    android:id="@+id/jamaat_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="Jamaat N/A"
                    android:textColor="#B3FFFFFF"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:gravity="end"/>
                <Chronometer
                    android:id="@+id/jamaat_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#26A69A"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Row 2: 4 prayer times (excludes current prayer) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <!-- Slot 1 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/row_label_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/row_time_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>

        <!-- Slot 2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/row_label_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/row_time_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>

        <!-- Slot 3 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/row_label_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/row_time_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>

        <!-- Slot 4 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/row_label_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeMaxTextSize="15sp"
                android:autoSizeStepGranularity="1sp"/>
            <TextView
                android:id="@+id/row_time_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeStepGranularity="1sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Row 3: Hijri + Bangla date (line 1) + location (line 2) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp">

        <!-- Line 1: App icon + calendar icon + Hijri & Bangla date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@mipmap/launcher_icon"
                android:contentDescription="App icon"
                android:layout_marginEnd="4dp"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="#FFFFFF"
                android:contentDescription="Calendar"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/islamic_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Islamic Date"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Line 2: Location icon + name + refresh (bottom-right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:paddingStart="24dp">
            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#B3FFFFFF"
                android:contentDescription="Location"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:id="@+id/location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Location"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <ImageView
                android:id="@+id/refresh_button"
                android:layout_width="28dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:padding="5dp"
                android:src="@android:drawable/ic_popup_sync"
                android:tint="#111111"
                android:contentDescription="Refresh"
                android:clickable="true"
                android:scaleType="centerInside"
                android:background="@drawable/widget_refresh_button_bg"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

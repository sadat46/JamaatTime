<?xml version="1.0" encoding="utf-8"?>
<!--
  Premium prayer widget background.
  - Vertical gradient (#1A1A1F -> #0D0D12) replaces the flat translucent black.
  - 24dp corner radius (was 12dp) reads more modern on home screens.
  - 1px subtle stroke at ~8% white provides edge definition / glass feel.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#1A1A1F"
        android:endColor="#0D0D12" />
    <stroke
        android:width="1dp"
        android:color="#14FFFFFF" />
    <corners android:radius="24dp" />
</shape>
